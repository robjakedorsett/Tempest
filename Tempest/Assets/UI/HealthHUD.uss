.health-hud {
    position: absolute;
    left: 40px;
    bottom: 40px;
    flex-direction: column;
    align-items: flex-start;
}

.health-container {
    background-color: rgba(0, 0, 0, 0.6);
    padding: 8px 16px;
    border-radius: 4px;
}

.health-label {
    font-size: 28px;
    color: rgb(255, 255, 255);
    -unity-font-style: bold;
}

.health-label--low {
    color: rgb(255, 70, 50);
}
